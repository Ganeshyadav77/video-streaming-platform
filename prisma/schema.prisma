generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  username      String    @unique
  passwordHash  String
  avatarUrl     String?
  createdAt     DateTime  @default(now())
  videos        Video[]
  comments      Comment[]
}

model Video {
  id          String    @id @default(cuid())
  title       String
  description String?
  videoUrl    String?
  thumbnail   String?
  status      String    @default("PROCESSING")
  views       Int       @default(0)
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  comments    Comment[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Comment {
  id        String   @id @default(cuid())
  text      String
  userId    String
  videoId   String
  user      User     @relation(fields: [userId], references: [id])
  video     Video    @relation(fields: [videoId], references: [id])
  createdAt DateTime @default(now())
}
